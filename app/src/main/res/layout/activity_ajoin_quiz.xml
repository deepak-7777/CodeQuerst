<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Loading Layout -->
    <LinearLayout
        android:id="@+id/loadingJoinQuiz"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressbarJoinQuiz"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminate="true" />

    </LinearLayout>

    <!-- Main Quiz Content -->
    <LinearLayout
        android:id="@+id/contentJoinQuiz"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarJoinQuiz"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:paddingTop="38dp"
            android:background="@color/colorControlNormal"
            app:titleTextAppearance="@style/ToolbarTitleBold">

            <TextView
                android:id="@+id/backJoinQuizActivity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="5dp"
                android:background="@drawable/back"
                android:contentDescription="Back Button"/>

            <TextView
                android:id="@+id/titleJoinQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="C Language"
                android:textColor="@color/TextColor"
                android:textStyle="bold"
                android:gravity="center"
                android:textSize="22sp" />
        </androidx.appcompat.widget.Toolbar>

        <!-- Timer Layout -->
        <FrameLayout
            android:id="@+id/timerJoinQuiz"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="56dp"
            android:gravity="center">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/circularProgressJoinQuiz"
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:indicatorSize="120dp"
                app:trackThickness="8dp"
                app:indicatorColor="@android:color/holo_red_light"
                app:trackColor="#D057C3"
                android:indeterminate="false"
                android:max="60"
                android:progress="25"/>

            <TextView
                android:id="@+id/tvTimerJoinQuiz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25"
                android:textSize="40sp"
                android:textColor="@color/HotPink"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="16dp">

            <!-- Question Text -->
            <TextView
                android:id="@+id/tvQuestionJoinQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Question will appear here"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="@drawable/bg_question"
                android:layout_marginBottom="16dp" />

            <!-- Options -->
            <RadioGroup
                android:id="@+id/radioGroupJoinQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/option1JoinQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="@drawable/rounded_option_bg"
                    android:text="Option 1"
                    android:layout_marginBottom="5dp"
                    android:textColor="@color/iconColor" />

                <RadioButton
                    android:id="@+id/option2JoinQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_option_bg"
                    android:textColor="@color/iconColor"
                    android:layout_marginBottom="5dp"
                    android:text="Option 2"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/option3JoinQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_option_bg"
                    android:textColor="@color/iconColor"
                    android:layout_marginBottom="5dp"
                    android:text="Option 3"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/option4JoinQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_option_bg"
                    android:textColor="@color/iconColor"
                    android:layout_marginBottom="5dp"
                    android:text="Option 4"
                    android:padding="12dp" />
            </RadioGroup>

            <!-- Question Counter -->
            <TextView
                android:id="@+id/tvCounterJoinQuiz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 10"
                android:textColor="@color/TextColor"
                android:background="@drawable/rounded_option_bg"
                android:textStyle="bold"
                android:padding="8dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:textSize="16sp" />

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
