<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:orientation="horizontal">
    <!-- Header showing correct answers / total questions -->
    <TextView
        android:id="@+id/tvCorrectAnswers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Correct Answer  "
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvTotalQuestions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10"
        android:textSize="16sp"
        android:textAlignment="center" />

    </LinearLayout>

    <!-- Main Card -->
    <LinearLayout
        android:id="@+id/cardLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_card_background"
        android:elevation="4dp"
        android:gravity="center"
        android:padding="24dp">

        <!-- Profile Image -->
        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_background"
            android:padding="4dp"
            android:layout_marginBottom="16dp" />

        <!-- Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roxane"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Rank -->
        <TextView
            android:id="@+id/tvRank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rank 432"
            android:textColor="#555555"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Congratulations Message -->
        <TextView
            android:id="@+id/tvCongrats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Congratulations, you've completed this quiz!"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textAlignment="center"
            android:layout_marginBottom="18dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Let's keep testing your knowledge by playing more quizzes!"
            android:textColor="#777777"
            android:textStyle="italic"
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <!-- Explore More Button -->

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnExploreMore"
            style="@android:style/Widget.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fsub_bg"
            android:padding="12dp"
            android:text="Explore More"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
