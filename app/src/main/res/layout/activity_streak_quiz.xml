<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.LevelQuizActivity">

    <!-- 🔹 Fullscreen Loading Overlay -->
    <LinearLayout
        android:id="@+id/streakLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="10dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressBarStreak"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminate="true" />
    </LinearLayout>

    <!-- 🔹 Main content (Toolbar + Questions) -->
    <LinearLayout
        android:id="@+id/streakAll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/streakToolbar"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:paddingTop="38dp"
                android:background="@color/colorControlNormal"
                app:titleTextAppearance="@style/ToolbarTitleBold">

                <TextView
                    android:id="@+id/tvTitleStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day"
                    android:textColor="@color/TextColor"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:textSize="22sp"
                    android:paddingStart="12sp" />
            </androidx.appcompat.widget.Toolbar>
        </androidx.cardview.widget.CardView>

        <!-- Timer Layout -->
        <FrameLayout
            android:id="@+id/timerStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="56dp"
            android:gravity="center">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/circularProgressStreak"
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:indicatorSize="120dp"
                app:trackThickness="8dp"
                app:indicatorColor="@android:color/holo_red_light"
                app:trackColor="#D057C3"
                android:indeterminate="false"
                android:max="60"
                android:progress="25" />

            <TextView
                android:id="@+id/tvTimerStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25"
                android:textSize="40sp"
                android:textColor="@color/HotPink"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- Question + Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvQuestionStreak"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Question will appear here"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="@drawable/bg_question"
                android:layout_marginBottom="16dp" />

            <RadioGroup
                android:id="@+id/radioGroupStreak"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/option1Streak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="Option 1"
                    android:layout_marginBottom="5dp"
                    android:textColor="@color/TextColor" />

                <RadioButton
                    android:id="@+id/option2Streak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/TextColor"
                    android:layout_marginBottom="5dp"
                    android:text="Option 2"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/option3Streak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/TextColor"
                    android:layout_marginBottom="5dp"
                    android:text="Option 3"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/option4Streak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/TextColor"
                    android:layout_marginBottom="5dp"
                    android:text="Option 4"
                    android:padding="12dp" />
            </RadioGroup>

            <TextView
                android:id="@+id/tvCounterStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 10"
                android:textColor="@color/TextColor"
                android:background="@drawable/rounded_option_bg"
                android:textStyle="bold"
                android:padding="8dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:textSize="16sp" />
        </LinearLayout>


    </LinearLayout>



</FrameLayout>
