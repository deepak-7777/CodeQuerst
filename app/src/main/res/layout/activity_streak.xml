<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/streakToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorControlNormal"
            android:paddingTop="45dp"
            app:titleTextAppearance="@style/ToolbarTitleBold">

            <TextView
                android:id="@+id/backStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="5sp"
                android:background="@drawable/back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Streak"
                android:textColor="@color/TextColor"
                android:textStyle="bold"
                android:textSize="21dp"
                android:paddingStart="12sp" />

<!--            <ImageView-->
<!--                android:id="@+id/heartStreak"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:src="@drawable/ic_privacy"-->
<!--                android:layout_marginEnd="5dp"-->
<!--                android:textSize="21dp"-->
<!--                android:background="@drawable/rounded_option_bg"-->
<!--                android:paddingHorizontal="10dp"-->
<!--                android:paddingVertical="2dp"-->
<!--                android:layout_gravity="end"/>-->

        </androidx.appcompat.widget.Toolbar>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/loadingProfile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressbar"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/iconColor" />
    </LinearLayout>

        <LinearLayout
            android:id="@+id/cardLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:elevation="4dp"
            android:layout_marginTop="50dp"
            android:gravity="center"
            android:padding="16dp">

            <FrameLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_marginBottom="16dp">

                <!-- Circular outline -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/streak_circle_outline" />

                <!-- Inner text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/streak_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="48sp"
                        android:textColor="#FF9600"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="days"
                        android:textSize="14sp"
                        android:textColor="#FF9600"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Small flame icon -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:tint="#A8572F" />
            </FrameLayout>

            <!-- Day circles -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <!-- Repeat for each day -->
                <TextView
                    android:id="@+id/day1"
                    style="@style/DayCircleStyle"
                    android:text="M" />
                <TextView
                    android:id="@+id/day2"
                    style="@style/DayCircleStyle"
                    android:text="T" />
                <TextView
                    android:id="@+id/day3"
                    style="@style/DayCircleStyle"
                    android:text="W" />
                <TextView
                    android:id="@+id/day4"
                    style="@style/DayCircleStyle"
                    android:text="T" />
                <TextView
                    android:id="@+id/day5"
                    style="@style/DayCircleStyle"
                    android:text="F" />
                <TextView
                    android:id="@+id/day6"
                    style="@style/DayCircleStyle"
                    android:text="S" />
                <TextView
                    android:id="@+id/day7"
                    style="@style/DayCircleStyle"
                    android:text="S" />
            </LinearLayout>

            <!-- Streak message -->
            <TextView
                android:id="@+id/dayStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" day streak!"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/TextColor"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You've reached your daily goal!\nPractice every day to build a streak."
                android:textColor="#666666"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Come back everyday"
                android:textColor="@color/iconColor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_continue"
                style="@android:style/Widget.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/guest_bg"
                android:padding="12dp"
                android:textColor="@color/white"
                android:layout_marginTop="30dp"
                android:text="Attempt  Quiz"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

</LinearLayout>
