<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/logout_dialog_bg"
    android:layout_margin="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Title -->
    <TextView
        android:id="@+id/logoutTitle"
        android:text="Logging Out"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/TextColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Message -->
    <TextView
        android:id="@+id/logoutMessage"
        android:text="Are you sure, do you want to logout?"
        android:textSize="15sp"
        android:textColor="@color/iconColor"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Buttons row -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/logoutDismiss"
            style="@android:style/Widget.Button"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:textColor="@color/white"
            android:background="@drawable/guest_bg"
            android:text="No"
            android:textSize="17sp"/>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/logoutSignIn"
            style="@android:style/Widget.Button"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:textColor="@color/white"
            android:background="@drawable/fsub_bg"
            android:text="Yes"
            android:textSize="18sp" />
    </LinearLayout>
</LinearLayout>
