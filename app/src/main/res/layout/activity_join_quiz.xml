<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/home_bg">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/joinToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="45dp"
        android:background="@color/home_bg"
        android:paddingBottom="7dp">

        <TextView
            android:id="@+id/backJoinQuiz"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@drawable/back"
            android:contentDescription="Back Button"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Join Quiz"
            android:textColor="@color/TextColor"
            android:textStyle="bold"
            android:textSize="21sp"
            android:paddingStart="12dp" />
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:orientation="vertical">
    <!-- Quiz Code Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Quiz Code to Join"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="5dp"
        android:textColor="@color/TextColor"
        android:paddingTop="16dp"
        android:paddingBottom="4dp" />

    <EditText
        android:id="@+id/etJoinQuizCode"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:hint="Enter Quiz Code"
        android:background="@drawable/createquiz_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/iconColor"
        android:inputType="text" />

    <!-- Join Button Below EditText -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnJoinQuiz"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Join &amp; Start"
        android:layout_marginTop="32dp"
        android:background="@drawable/fsub_bg"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/joinProgressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Joined Quizzes Section -->
<!--    <TextView-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:text="Your Joined Quizzes"-->
<!--        android:layout_marginTop="30dp"-->
<!--        android:textSize="18sp"-->
<!--        android:textStyle="bold"-->
<!--        android:textColor="@color/TextColor"-->
<!--        android:paddingTop="8dp"-->
<!--        android:paddingBottom="8dp" />-->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvJoinedQuizzes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:paddingTop="4dp"/>
    </LinearLayout>

</LinearLayout>
