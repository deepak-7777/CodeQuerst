<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/swipeRanking"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/RankingRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Podium Top 3 -->
        <LinearLayout
            android:id="@+id/podiumLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3"
            android:padding="8dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Second Place -->
            <LinearLayout
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <FrameLayout
                    android:layout_width="70dp"
                    android:layout_height="90dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgSecond"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:scaleType="centerCrop"
                        android:layout_gravity="top|center_horizontal"/>

                    <TextView
                        android:id="@+id/badgeSecond"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:translationY="-10dp"
                        android:background="@drawable/podium_silver"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="13sp"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvSecondName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textSize="14sp"
                    android:ellipsize="end"
                    android:singleLine="true"/>

                <TextView
                    android:id="@+id/tvSecondPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pts"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- First Place -->
            <LinearLayout
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="110dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgFirst"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="top|center_horizontal"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/badgeFirst"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:background="@drawable/podium_gold"
                        android:gravity="center"
                        android:text="1"
                        android:translationY="-9dp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvFirstName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textSize="16sp"
                    android:ellipsize="end"
                    android:singleLine="true"/>

                <TextView
                    android:id="@+id/tvFirstPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pts"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Third Place -->
            <LinearLayout
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:id="@+id/weeklyDialogBox"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_info" />

                <FrameLayout
                    android:layout_width="70dp"
                    android:layout_height="90dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/imgThird"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:scaleType="centerCrop"
                        android:layout_gravity="top|center_horizontal"/>

                    <TextView
                        android:id="@+id/badgeThird"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:translationY="-15dp"
                        android:background="@drawable/podium_bronze"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvThirdName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textSize="14sp"
                    android:ellipsize="end"
                    android:singleLine="true"/>

                <TextView
                    android:id="@+id/tvThirdPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pts"
                    android:textSize="12sp"/>
            </LinearLayout>

        </LinearLayout>


<!--        &lt;!&ndash; Divider &ndash;&gt;-->
<!--        <View-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="1dp"-->
<!--            android:background="#CCCCCC"-->
<!--            android:layout_marginVertical="8dp"/>-->

        <!-- RecyclerView for rest of leaderboard -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"/>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressRanking"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/iconColor"
            android:visibility="gone"/>

        <!-- Empty State Layout (visible only when no data) -->
        <LinearLayout
            android:id="@+id/emptyStateLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="16dp">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_empty_leaderboard"
                android:contentDescription="No Data" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No quiz data available yet!"
                android:textSize="16sp"
                android:textColor="@color/iconColor"
                android:layout_marginTop="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTryQuiz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Try a Quiz"
                android:textColor="@color/white"
                android:background="@drawable/fsub_bg"
                android:layout_marginTop="12dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
